{
  "name": "tsjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Trusted Server tsjs TypeScript library with queue and simple banner rendering.",
  "scripts": {
    "build": "node build-all.mjs",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\""
  },
  "dependencies": {
    "prebid.js": "^11.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.10.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.2.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.0.8"
  }
}
