# compiled output
/bin
/pkg
/target
**/target/

# Node.js dependencies and build output (any crate, e.g. crates/trusted-server-js)
**/node_modules/
**/dist/
**/.npm
**/.eslintcache
# Auto-generated JS module index
**/src/generated-modules.ts

# EdgeZero local KV store (created by edgezero-adapter-axum framework)
.edgezero/

# env
.env*

# backup
**/*.rs.bk
src/main_*.rs
src/*.html

# OS
.DS_Store

# IDE
.specstory
.vscode

# Claude Code — ignore all, then whitelist shared config
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/

# SSL certificates
*.pem

/guest-profiles
/benchmark-results/**

# Playwright browser tests
/crates/trusted-server-integration-tests/browser/node_modules/
/crates/trusted-server-integration-tests/browser/test-results/
/crates/trusted-server-integration-tests/browser/playwright-report/
/crates/trusted-server-integration-tests/browser/.browser-test-state.json
